# BIMFabrikHH API Environment Configuration
# Copy this file to .env and modify as needed
# Copyright (C) 2025 Freie und Hansestadt Hamburg, Landesbetrieb Geoinformation und Vermessung
# BIM-Leitstelle, Ahmed Salem <ahmed.salem@gv.hamburg.de>

# Base Configuration
BASE_URL=http://localhost:8083

# Server Configuration
API_HOST=0.0.0.0
API_PORT=8083

# Main API URLs for the 3 apps
# Tree API (baum app)
TREES_API_URL=https://api.hamburg.de/datasets/v1/strassenbaumkataster/collections/strassenbaumkataster_hh/items

# Tree API Hafen (harbor trees)
TREES_HAFEN_API_URL=https://api.hamburg.de/datasets/v1/strassenbaumkataster_hafen/collections/strassenbaumkataster_hpa/items

# DGM API (dgm app)
DGM_TILES_API_URL=https://api.hamburg.de/datasets/v1/uebersicht_kachelbezeichnungen/collections/lgv_kachel_dk5_1km_utm/items

# API Settings
API_TIMEOUT=30
API_DEFAULT_LIMIT=2000
API_DEFAULT_CRS=http://www.opengis.net/def/crs/EPSG/0/25832

# Output URLs for generated files
URL_OUTPUT_HTTP=http://localhost:8083/output
URL_OUTPUT_HTTPS=https://localhost:8083/output

# File system paths
OUTPUT_FOLDER_PATH=output

# Hamburg Open Data - CityGML and DGM source
DATA_BASE_URL=https://daten-hamburg.de/BIM/daten_bimfabrikhh
DATA_LOD1_FOLDER=LoD1-DE_HH_2023
DATA_LOD2_FOLDER=LoD2-DE_HH_2025
DATA_DGM_FOLDER=dgm_HH_2022

# Redis configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0